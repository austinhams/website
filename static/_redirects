# Cloudflare Pages redirects.
# Syntax: <source> <destination> <status>
# Hugo generates trailing-slash URLs (/<slug>/), so most legacy WP URLs
# already match. Add custom redirects below as needed.

# Example:
# /old-path/  /new-path/  301

# AARCover newsletter archive moved from individual posts to a single
# data-driven page (/aarcover-archive/).
/categories/aarcover-archive/  /aarcover-archive/  301
/aarcover-newsletter-*         /aarcover-archive/  301
